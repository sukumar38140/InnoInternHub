{
  "buildCommand": "cd web && npm run build",
  "installCommand": "npm install --prefix web",
  "outputDirectory": "web/.next",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_API_URL": "@innohub_api_url",
    "NEXT_PUBLIC_APP_URL": "@innohub_app_url"
  },
  "functions": {
    "web/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/dashboard",
      "destination": "/dashboard/student",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/:path*",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=()"
        }
      ]
    },
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    }
  ],
  "regions": ["iad1"],
  "crons": []
}
